# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub

# PostgreSQL connection string from Neon
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# Comma-separated list of allowed frontend origins (your Vercel URL)
# Example: CORS_ORIGINS=https://pfms.vercel.app
CORS_ORIGINS=https://your-app.vercel.app
